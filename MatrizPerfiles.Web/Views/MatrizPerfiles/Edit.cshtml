@model MatrizPerfiles.Web.ViewModels.MatrizPerfilViewModel
@{
    ViewData["Title"] = "Editar Registro de Matriz";
}

<div class="card">
    <div class="card-header bg-white border-bottom-0 pb-0">
        <div class="d-flex justify-content-between align-items-center">
            <h5 class="mb-0 text-primary"><i class="bi bi-pencil-square me-2"></i>Editar Registro (ID: @Model.MatrizPerfil.Id)</h5>
            <span class="badge bg-secondary">Creado: @Model.MatrizPerfil.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</span>
        </div>
    </div>
    <form asp-action="Edit">
        <div asp-validation-summary="ModelOnly" class="text-danger ps-4 pt-2"></div>
        <input type="hidden" asp-for="MatrizPerfil.Id" />
        <div class="card-body p-0">
            <partial name="_FormFields" model="Model" />
        </div>
        <div class="card-footer bg-light text-end p-3">
            <a asp-action="Index" class="btn btn-light border me-2">Cancelar</a>
            <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i> Actualizar Registro</button>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
