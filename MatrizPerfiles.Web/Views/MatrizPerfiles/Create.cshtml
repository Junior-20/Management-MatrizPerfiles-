@model MatrizPerfiles.Web.ViewModels.MatrizPerfilViewModel
@{
    ViewData["Title"] = "Nuevo Registro de Matriz";
}

<div class="card">
    <div class="card-header bg-white border-bottom-0 pb-0">
        <h5 class="mb-0 text-primary"><i class="bi bi-file-earmark-plus me-2"></i>Crear Registro</h5>
    </div>
    <form asp-action="Create">
        <div asp-validation-summary="ModelOnly" class="text-danger ps-4 pt-2"></div>
        <div class="card-body p-0">
            <partial name="_FormFields" model="Model" />
        </div>
        <div class="card-footer bg-light text-end p-3">
            <a asp-action="Index" class="btn btn-light border me-2">Cancelar</a>
            <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i> Guardar Registro</button>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
