@model MatrizPerfiles.Web.Models.PbiMatrizPerfil
@{
    ViewData["Title"] = "Detalle del Registro";
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center py-3">
        <h5 class="mb-0"><i class="bi bi-card-text me-2"></i> Detalles (ID: @Model.Id)</h5>
        <div class="badge bg-light text-primary fs-6">
            <i class="bi bi-calendar me-1"></i> Creado: @Model.FechaCreacion.ToString("dd/MM/yyyy HH:mm") UTC
        </div>
    </div>
    <div class="card-body p-4">
        
        <h6 class="text-primary fw-bold text-uppercase border-bottom pb-2 mb-3">Identificación</h6>
        <div class="row mb-4">
            <div class="col-md-4 mb-2">
                <span class="text-muted d-block small fw-bold">Empresa</span>
                <span class="fs-6">@(Model.Empresa ?? "-")</span>
            </div>
            <div class="col-md-4 mb-2">
                <span class="text-muted d-block small fw-bold">Sistema</span>
                <span class="fs-6 text-dark fw-bold">@(Model.Sistema?.Nombre ?? "-")</span>
            </div>
            <div class="col-md-4 mb-2">
                <span class="text-muted d-block small fw-bold">Puesto</span>
                <span class="fs-6 text-dark fw-bold">@(Model.Puesto?.Nombre ?? "-")</span>
            </div>
            <div class="col-md-4 mb-2">
                <span class="text-muted d-block small fw-bold">Código</span>
                <span class="fs-6">@(Model.Codigo ?? "-")</span>
            </div>
            <div class="col-md-8 mb-2">
                <span class="text-muted d-block small fw-bold">Unidad Organizativa</span>
                <span class="fs-6">@(Model.DescripcionUnidadOrganizativa ?? "-")</span>
            </div>
        </div>

        <h6 class="text-primary fw-bold text-uppercase border-bottom pb-2 mb-3 mt-4">Navegación</h6>
        <div class="row align-items-center mb-4">
            <div class="col-md-12 d-flex flex-wrap gap-2 text-center text-muted" style="font-size: 0.9rem;">
                <!-- Breadcrumb-style navigation display -->
                <div class="bg-light px-3 py-2 rounded"><strong>Módulo:</strong> @(Model.Modulo ?? "-")</div> <i class="bi bi-chevron-right mt-2 text-primary"></i>
                <div class="bg-light px-3 py-2 rounded"><strong>SubMódulo:</strong> @(Model.SubModulo ?? "-")</div> <i class="bi bi-chevron-right mt-2 text-primary"></i>
                <div class="bg-light px-3 py-2 rounded"><strong>Menú:</strong> @(Model.Menu ?? "-")</div> <i class="bi bi-chevron-right mt-2 text-primary"></i>
                <div class="bg-light px-3 py-2 rounded"><strong>Opción:</strong> @(Model.Opcion ?? "-")</div>
            </div>
        </div>

        <h6 class="text-primary fw-bold text-uppercase border-bottom pb-2 mb-3 mt-4">Programa y Clasificación</h6>
        <div class="row mb-4">
            <div class="col-md-4 mb-2">
                <span class="text-muted d-block small fw-bold">Programa</span>
                <span class="fs-6">@(Model.Programa ?? "-")</span>
            </div>
            <div class="col-md-4 mb-2">
                <span class="text-muted d-block small fw-bold">Función Rol Asoc.</span>
                <span class="fs-6 badge bg-info text-dark">@(Model.FuncionRolAsociado ?? "-")</span>
            </div>
            <div class="col-md-4 mb-2">
                <span class="text-muted d-block small fw-bold">Tipo de Perfil</span>
                <span class="fs-6">@(Model.TipoDePerfil ?? "-")</span>
            </div>
            <div class="col-md-12 mb-2">
                <span class="text-muted d-block small fw-bold">Descripción</span>
                <p class="fs-6 bg-light p-3 rounded">@(Model.Descripcion ?? "-")</p>
            </div>
        </div>

        <h6 class="text-primary fw-bold text-uppercase border-bottom pb-2 mb-3 mt-4">Niveles de Jerarquía</h6>
        <div class="table-responsive">
            <table class="table table-sm table-bordered">
                <thead class="table-light text-center">
                    <tr>
                        <th>N1</th><th>N2</th><th>N3</th><th>N4</th><th>N5</th><th>N6</th><th>N7</th>
                    </tr>
                </thead>
                <tbody class="text-center">
                    <tr>
                        <td>@(Model.FuncionNivel1 ?? "-")</td>
                        <td>@(Model.FuncionNivel2 ?? "-")</td>
                        <td>@(Model.FuncionNivel3 ?? "-")</td>
                        <td>@(Model.FuncionNivel4 ?? "-")</td>
                        <td>@(Model.FuncionNivel5 ?? "-")</td>
                        <td>@(Model.FuncionNivel6 ?? "-")</td>
                        <td>@(Model.FuncionNivel7 ?? "-")</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
    <div class="card-footer bg-white p-3 text-end d-flex gap-2 justify-content-end">
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Volver a la Lista</a>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary"><i class="bi bi-pencil me-1"></i> Editar</a>
    </div>
</div>
