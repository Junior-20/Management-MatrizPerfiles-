@model MatrizPerfiles.Web.Models.Puesto
@{
    ViewData["Title"] = "Nuevo Puesto";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-plus-circle me-1"></i> Agregar Puesto
            </div>
            <div class="card-body">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    
                    <div class="mb-3">
                        <label asp-for="Nombre" class="form-label text-muted fw-bold">Nombre del Puesto <span class="text-danger">*</span></label>
                        <input asp-for="Nombre" class="form-control" placeholder="Ej. Analista Funcional" />
                        <span asp-validation-for="Nombre" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <a asp-action="Index" class="btn btn-light border">Cancelar</a>
                        <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i> Guardar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
